# ============================================================================
# Clarity（心虫/草履虫）环境变量配置
# ============================================================================
# 复制此文件为 .env 并根据需要修改变量值：
#   cp .env.example .env
#
# 所有变量均为可选，设默认值的变量可留空。
# 除非特别说明，缺失变量不影响基本运行。
# ============================================================================

# ─── 加密密钥 ─────────────────────────────────────────────────────────────────

# AES-256 加密密钥（base64 编码，32 字节）
# 用于 LEARNED 层记忆的 AES-256-GCM 加密。
# 推荐使用环境变量而非 .aes-key 文件（文件可能被复制导致数据泄露）。
# 生成方式: node -e "process.stdout.write(require('crypto').randomBytes(32).toString('base64'))"
# HEARTFLOW_AES_KEY=your-base64-32-byte-key

# Q-table HMAC 签名密钥（ASCII 字符串）
# 用于 Q-table 完整性校验的 HMAC-SHA256 签名。
# 推荐使用环境变量而非 .hmac-key 文件。
# 生成方式: node -e "process.stdout.write(require('crypto').randomBytes(32).toString('base64'))"
# HEARTFLOW_QTABLE_HMAC_KEY=your-hmac-key

# ─── 数据治理 ─────────────────────────────────────────────────────────────────

# 数据最小化模式（设置任意非空值启用）
# 启用后，MEANINGFUL_MEMORY 持久化需要同时启用此变量和 HEARTFLOW_USER_CONSENT。
# 未设置时，持久化被静默阻止（可通过启动日志查看状态）。
# HEARTFLOW_DATA_MINIMIZATION=1

# 用户同意（设置任意非空值启用）
# 启用后，允许 MEANINGFUL_MEMORY 持久化数据。
# 同时需要 HEARTFLOW_DATA_MINIMIZATION=1 才能实际生效。
# HEARTFLOW_USER_CONSENT=1

# ─── 自我修改 ─────────────────────────────────────────────────────────────────

# 启用自我代码修改（默认禁用）
# 设置为 1 时启用 SelfModifier 模块的代码生成能力。
# 警告：此功能仅适用于沙箱/开发环境，会生成并可能直接修改项目文件。
# HEARTFLOW_ENABLE_SELF_MODIFICATION=1

# ─── 调试 ─────────────────────────────────────────────────────────────────────

# 调试模式（设置任意非空值启用）
# 启用后输出各模块的详细调试日志。
# HEARTFLOW_DEBUG=1

# ─── 运行时环境 ───────────────────────────────────────────────────────────────

# 运行环境标识（development / production）
# production 模式下错误处理器会隐藏敏感信息。
# HEARTFLOW_ENV=development

# ─── Q-learning 参数 ──────────────────────────────────────────────────────────

# Q-learning 初始探索率（浮点数，默认 0.1）
# 控制 Q-table 学习中随机探索的概率。
# HEARTFLOW_RL_EPSILON=0.1

# Q-learning 探索率衰减系数（浮点数，默认 0.99）
# 每轮学习后 epsilon 的衰减倍率。
# HEARTFLOW_RL_EPSILON_DECAY=0.99

# ─── LLM 外部调用 ─────────────────────────────────────────────────────────────

# LLM API 密钥
# 用于 IntentLayer 等需要外部 LLM 调用的模块。
# 缺省时相关功能静默跳过。
# LLM_API_KEY=sk-your-key-here

# LLM API 端点
# 可指定自定义 LLM API 地址（如兼容 OpenAI 格式的代理）。
# 缺省时使用模块内置默认端点。
# LLM_ENDPOINT=https://api.openai.com/v1

# ─── Node.js ──────────────────────────────────────────────────────────────────

# Node.js 运行环境（development / production / test）
# 部分模块根据此变量调整行为（如缓存策略）。
NODE_ENV=development
