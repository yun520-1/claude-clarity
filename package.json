{
  "name": "claude-clarity",
  "version": "1.1.5",
  "description": "草履虫 / Clarity v1.1.5 — AI 认知内核。单细胞，能进化。",
  "main": "src/core/clarity.js",
  "bin": {
    "clarity": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "check": "find src bin -name '*.js' -not -path '*/node_modules/*' -print0 | xargs -0 -n 1 node --check",
    "test": "node tests/integration.test.js && node tests/v2_0_19.test.js && jest",
    "test:jest": "jest",
    "test:old": "node tests/integration.test.js && node tests/v2_0_19.test.js",
    "demo": "node -e \"const {createClarity}=require('./src/core/clarity.js'); const fs=require('fs'); const hf=createClarity({rootPath:\".\"}); hf.start(); console.log('Version:',fs.readFileSync('./VERSION','utf8').trim()); hf.stop();\"",
    "audit": "npm audit --audit-level=high"
  },
  "files": [
    "CHANGELOG.md",
    "SKILL.md",
    "VERSION",
    "bin/",
    "src/core/**/*.js",
    "src/core/**/*.json",
    "src/core/**/*.md",
    "src/psychology/**/*.js",
    "src/memory/**/*.js",
    "src/identity/**/*.js",
    "references/"
  ],
  "keywords": [
    "cognitive-engine",
    "memory-system",
    "self-verification",
    "reasoning",
    "consciousness",
    "ontology",
    "psychology",
    "emotion",
    "dream-engine",
    "counterfactual",
    "topic-isolation",
    "thought-chain",
    "identity-preservation",
    "entropy",
    "philosophy",
    "decision-verification",
    "lesson-learning",
    "q-learning",
    "code-generation",
    "agent-orchestration",
    "process-management"
  ],
  "security": {
    "warnings": [
      "此技能包含高级 AI 认知能力。desktop-agent 和 video-generate 等子技能包含高风险功能，需要明确用户授权才能使用。",
      "不会自动发送数据到外部服务。所有网络通信需要显式配置。",
      "不会自动写入 API 密钥到环境变量文件。用户必须显式提供密钥。"
    ]
  },
  "license": "MIT",
  "overrides": {
    "protobufjs": "7.5.9"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  }
}
